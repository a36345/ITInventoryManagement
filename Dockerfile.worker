FROM python:3.11-slim

RUN apt-get update \
 && apt-get install -y --no-install-recommends iputils-ping libsqlcipher-dev \
 && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements-linux.txt .
RUN pip install --no-cache-dir -r requirements-linux.txt

COPY core/ core/
COPY services/ services/

ENV ITINV_DB=/data/inventory.db
ENV ITINV_HOME=/data

CMD ["python", "services/discovery_worker.py", "--loop", "24"]
